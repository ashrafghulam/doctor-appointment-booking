# ── Server ───────────────────────────────────────────────
PORT=3000

# ── MongoDB (use MongoDB Atlas connection string for production) ──
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/doctor_appointment?retryWrites=true&w=majority

# ── Authentication ───────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_string

# ── Default Admin Credentials (created on first run) ─────
ADMIN_EMAIL=admin@doctor.com
ADMIN_PASSWORD=change_this_to_a_strong_password

# ── SMS Provider (optional – for future production use) ──
# SMS_PROVIDER=twilio
# SMS_API_KEY=your_api_key_here
# SMS_SENDER_ID=DrTanzeel
